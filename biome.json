{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "files": {
    "includes": ["**/*.js", "**/*.ts", "**/*.tsx"],
    "ignoreUnknown": true
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "complexity": {
        "noStaticOnlyClass": "error",
        "noThisInStatic": "error",
        "noUselessThisAlias": "error",
        "useArrowFunction": "error",
        "noForEach": "error",
        "useFlatMap": "error",
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 7
          }
        }
      },
      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "noUnusedTemplateLiteral": "error"
      },
      "suspicious": {
        "noVar": "error",
        "noDoubleEquals": "error",
        "noConsole": "error",
        "noSkippedTests": "error",
        "noFocusedTests": "error",
        "noExplicitAny": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/client/**", "src/static/admin.js", "src/static/scanner.js", "src/static/embed.js", "src/static/iframe-resizer-parent.js", "src/static/iframe-resizer-child.js"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["test/**/*.js", "test/**/*.ts", "test/**/*.tsx", "src/test-utils/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedFunctionParameters": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": {
              "level": "error",
              "options": {
                "maxAllowedComplexity": 30
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/fp.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["src/index.ts", "src/lib/logger.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
